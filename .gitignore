# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets — never commit, even though none exist in this repo as of
# 2026-07-16 (verified before making this repo public).
.env
.env.*
*.pem
*.key
!android/**/*.jks

# Cloudflare Worker's own build output/deps — not app source.
cloudflare/soutuk-worker/node_modules/
cloudflare/soutuk-worker/.wrangler/
